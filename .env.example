# Personal Finance Tracker Environment Variables Example

# This file contains example environment variables for the Personal Finance Tracker application.
# Copy this file to `.env` and fill in your actual values.

# --- Application Environment ---
APP_ENV=development
APP_DEBUG=true

# --- Database Configuration (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=personal_finance_db
DB_USER=finance_user
DB_PASSWORD=your_db_password

# --- PHP API Configuration ---
# The base URL for the PHP API. This is primarily for internal use if the API needs to generate absolute URLs,
# or for documentation. The Angular frontend will use NG_APP_API_BASE_URL.
API_BASE_URL=http://localhost:8000/api

# CORS: Comma-separated list of allowed origins for API requests.
# In production, this should be your frontend's domain (e.g., http://your-finance-app.com).
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# JWT Secret for authentication (if implemented). Generate a strong, random string.
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# --- Frontend (Angular) Configuration ---
# The base URL where the Angular application can find the PHP API.
# This variable will be picked up by the Angular build process (e.g., via environment.ts).
NG_APP_API_BASE_URL=http://localhost:8000/api

# --- Cross-Project Microservice URLs (for integration/referencing) ---
# These URLs point to other services within the larger interconnected system.
# The finance tracker might integrate with these for various purposes (e.g., user authentication,
# fetching product data for expense tracking, displaying relevant quizzes, etc.).
QUIZ_APP_API_URL=http://localhost:3001/api/quiz
ECOMMERCE_API_URL=http://localhost:3002/api/products
WEATHER_API_URL=http://localhost:3003/api/weather
WHITEBOARD_API_URL=http://localhost:3004/api/whiteboard