# Node.js / Angular
node_modules/
dist/
.angular/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
coverage/
.env # Actual environment variables, keep .env.example in VCS

# PHP / Composer
vendor/
storage/ # For logs, cache, sessions, etc.
*.log # General log files generated by PHP or web server

# Environment variables
# Keep .env.example in VCS, but ignore the actual .env file
.env

# IDE and OS specific files
.DS_Store
Thumbs.db
.vscode/ # VS Code specific settings
.idea/ # IntelliJ/PHPStorm specific settings
*.swp # Vim swap files
*~ # Backup files from various editors

# Build artifacts
*.zip
*.tar.gz
*.rar

# Database
# Ignore actual database dumps or backup files
*.sql.bak
*.dump
*.sqlite
*.sqlite3